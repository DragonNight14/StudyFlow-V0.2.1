  "prefer_related_applications": false,
  "related_applications": [],
  "display_override": ["standalone", "minimal-ui"],
  "handle_links": "preferred",
  
  "icons": [
    {
      "src": "icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "icon-144x144.png",
      "sizes": "144x144",
      "type": "image/png",
      "purpose": "any"
    }
  ],
  
  "shortcuts": [
    {
      "name": "Add Assignment",
      "short_name": "Add",
      "description": "Add a new assignment",
      "url": "/index.html?view=add",
      "icons": [{"src": "icon-192x192.png", "sizes": "192x192"}]
    },
    {
      "name": "View All",
      "short_name": "All",
      "description": "View all assignments",
      "url": "/index.html?view=all",
      "icons": [{"src": "icon-192x192.png", "sizes": "192x192"}]
    },
    {
      "name": "Upgrade to Premium",
      "short_name": "Premium",
      "description": "Upgrade to premium features",
      "url": "/index.html?view=premium",
      "icons": [{"src": "icon-192x192.png", "sizes": "192x192"}]
    }
  ],
  
  "screenshots": [
    {
      "src": "/screenshots/dashboard.png",
      "sizes": "1080x1920",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Dashboard view"
    },
    {
      "src": "/screenshots/assignment-view.png",
      "sizes": "1080x1920",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Assignment details"
    }
  ],
  
  "payment": {
    "supported_delegations": [
      "shippingAddress",
      "payerName",
      "payerPhone",
      "payerEmail"
    ]
  },
  
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  
  "protocol_handlers": [
    {
      "protocol": "web+studyflow",
      "url": "/index.html?action=%s"
    }
  ],
  
  "edge_side_panel": {
    "preferred_width": 400
  }
}
